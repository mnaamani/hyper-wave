{
  "expo": {
    "name": "HyperWave",
    "slug": "hyperwave-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "io.hyperwave.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "HyperWave uses the camera to take your wave selfie."
      }
    },
    "android": {
      "package": "io.hyperwave.mobile",
      "permissions": ["CAMERA"]
    }
  }
}
