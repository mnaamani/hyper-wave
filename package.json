{
  "name": "hyperwave-desktop",
  "productName": "HyperWave",
  "version": "0.2.0",
  "upgrade": "pear://pwfsihrajqdzscrheaegd5n98xfo8qik9q4cpixjdenjniri718y",
  "description": "HyperWave \u2014 a worldwide P2P wave of moments (Tether Developers Cup). Electron desktop host at the repo root + the reusable Bare engine and wallets in packages/*; the mobile host in mobile/.",
  "license": "Apache-2.0",
  "author": "",
  "type": "commonjs",
  "main": "electron/main.js",
  "private": true,
  "workspaces": [
    "packages/*",
    "mobile"
  ],
  "scripts": {
    "postinstall": "node scripts/fix-bare-engines.js && node scripts/patch-secret-stream.js && node scripts/build-nsfw.mjs && node scripts/build-qr.mjs",
    "start": "electron-forge start -- --no-updates",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "ota:deploy": "node scripts/ota-deploy.mjs",
    "test": "npm test -w hyperwave-wallet && npm test -w hyperwave-engine && npm test -w hyperwave-wallet-tron && npm test -w hyperwave-wallet-cashu",
    "test:e2e:local": "npm run test:e2e:local -w hyperwave-engine",
    "test:e2e:onchain": "npm run test:e2e:onchain -w hyperwave-engine",
    "test:e2e:onchain:usdt": "npm run test:e2e:onchain:usdt -w hyperwave-engine",
    "test:e2e:cashu": "npm run test:e2e:cashu -w hyperwave-engine",
    "lint": "prettier --check . && lunte packages electron renderer workers scripts && eslint . && npm run lint:jsdoc -w hyperwave-wallet && npm run lint:jsdoc -w hyperwave-engine && npm run lint:jsdoc -w hyperwave-wallet-tron && npm run lint:jsdoc -w hyperwave-wallet-cashu",
    "format": "prettier --write . && lunte --fix packages electron renderer workers scripts"
  },
  "overrides": {
    "axios": "1.18.1",
    "ethers": {
      "ws": "8.21.0"
    },
    "tar": "7.5.19",
    "tmp": "0.2.7",
    "xcode": {
      "uuid": "11.1.1"
    },
    "hyperdht": "6.32.0"
  },
  "dependencies": {
    "bare-env": "^3.0.1",
    "bare-path": "^3.0.1",
    "bip39": "3.1.0",
    "corestore": "^7.9.1",
    "framed-stream": "^1.0.1",
    "graceful-goodbye": "^1.3.3",
    "hyperswarm": "^4.17.0",
    "hyperwave-engine": "^0.3.0",
    "hyperwave-wallet-cashu": "^0.3.0",
    "paparam": "^1.10.0",
    "pear-runtime": "^1.1.4",
    "which-runtime": "^1.3.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-msix": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@tensorflow/tfjs": "^4.22.0",
    "app-builder-lib": "^26.8.1",
    "electron": "^40.2.1",
    "electron-forge-plugin-prune-prebuilds": "^1.0.0",
    "electron-forge-plugin-universal-prebuilds": "^1.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "lunte": "^1.6.0",
    "nsfwjs": "^4.3.0",
    "pear-electron-forge-maker-appimage": "^2.0.0",
    "pear-electron-forge-maker-flatpak": "^0.0.6",
    "pear-electron-forge-maker-snap": "^0.0.10",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0",
    "qrcode-generator": "^1.5.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=24"
  },
  "volta": {
    "node": "24.18.0"
  }
}
