{
  "name": "hyperwave-monorepo",
  "private": true,
  "description": "HyperWave — global P2P stadium wave (Tether Developers Cup). Monorepo: the reusable Bare engine (packages/hyper-wave) + hosts (apps/*).",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "node scripts/fix-bare-engines.js",
    "test": "npm test -w hyper-wave",
    "test:e2e:local": "npm run test:e2e:local -w hyper-wave",
    "test:e2e:onchain": "npm run test:e2e:onchain -w hyper-wave",
    "start": "npm start -w hyperwave-desktop --",
    "lint": "prettier --check . && lunte packages apps/desktop scripts && eslint . && npm run lint:jsdoc -w hyper-wave",
    "format": "prettier --write . && lunte --fix packages apps/desktop scripts"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "lunte": "^1.6.0",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "volta": {
    "node": "24.18.0"
  }
}
