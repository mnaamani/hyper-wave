  <recommends>
    <display_length compare="ge">600</display_length>
  </recommends>
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <description>
    <p>HyperWave is a permissionless peer-to-peer relay where people around
    the world capture a moment together as a bitcoin-orange wave sweeps a
    ring of participants. No registration and no server: each peer joins a
    room-specific swarm and takes a fixed position on a shared ring.</p>
    <ul>
      <li>A deterministic wave sweeps the ring so everyone captures together</li>
      <li>Moments merge into a per-wave gallery with no indexer or admission</li>
      <li>Self-custodial wallets power burned participation fees and tips</li>
      <li>Peer-to-peer over-the-air updates with update-restart</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.mnaamani.HyperWave.desktop</launchable>
  <screenshots>
