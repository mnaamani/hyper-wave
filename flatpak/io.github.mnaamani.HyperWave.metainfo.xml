  <id>io.github.mnaamani.HyperWave</id>

  <name>HyperWave</name>
  <summary>A worldwide peer-to-peer wave of moments</summary>

  <metadata_license>Apache-2.0</metadata_license>
  <project_license>Apache-2.0</project_license>

  <developer id="io.github.mnaamani">
    <name>HyperWave</name>
  </developer>

  <content_rating type="oars-1.1"/>

  <url type="homepage">https://github.com/mnaamani/hyper-wave</url>
  <url type="help">https://github.com/mnaamani/hyper-wave/issues/new/choose</url>
  <url type="bugtracker">https://github.com/mnaamani/hyper-wave/issues</url>

  <releases>
    <release date="2026-07-23" version="0.2.0"/>
    <release date="2026-07-22" version="0.1.0"/>
